<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.0/phpunit.xsd"
    colors="true"
    stopOnError="false"
    stopOnFailure="false"
    cacheDirectory=".phpunit.cache">
    <php>
        <env name="STATES_PRIMARY_KEY_TYPE" value="uuid"/>
        <env name="STATES_CONTEXT_MORPH_TYPE" value="uuid"/>
        <env name="STATES_BOUNDARY_MORPH_TYPE" value="uuid"/>
        <env name="STATES_ACTOR_MORPH_TYPE" value="uuid"/>
    </php>
    <source>
        <include>
            <directory suffix=".php">./src</directory>
        </include>
        <exclude>
            <file>./src/StatesServiceProvider.php</file>
        </exclude>
    </source>
    <testsuites>
        <testsuite name="default">
            <directory suffix=".php">./tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
